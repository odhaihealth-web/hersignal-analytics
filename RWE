  const timeout=setTimeout(()=>controller.abort(),8000);
  try {
    const res=await fetch(SUPABASE_URL+'/rest/v1/checkins?order=checked_at.asc&limit=1000',{
      signal:controller.signal,
      headers:{'apikey':SUPABASE_ANON_KEY,'Authorization':'Bearer '+SUPABASE_ANON_KEY}
    });
    clearTimeout(timeout);
    if(!res.ok) throw new Error('HTTP '+res.status);
    const data=await res.json();
    if(!Array.isArray(data)||data.length===0){showState('Empty');return;}
    ALL_RECORDS=data;
    populateUserFilter(data);
    renderDashboard(data);
    showState('Dashboard');
  } catch(err) {
    clearTimeout(timeout);
    document.getElementById('errorMsg').textContent=err.name==='AbortError'?'Request timed out.':'Error: '+err.message;
    showState('Error');
  } finally { setRefreshSpinner(false); }
}


function renderDashboard(records) {
  renderMetrics(records); renderDonut(records); renderLine(records);
  renderBar(records); renderHistory(records);
  renderIntelligence(records); renderChecklist(records);
  renderNotes(records);
  document.getElementById('totalBadgeCount').textContent=ALL_RECORDS.length.toLocaleString();
}


function renderMetrics(records) {
  const avg=key=>{const v=records.map(r=>r[key]).filter(v=>v!=null&&!isNaN(v));return v.length?(v.reduce((a,b)=>a+b,0)/v.length).toFixed(1):'—';};
  document.getElementById('mTotal').textContent=records.length.toLocaleString();
  document.getElementById('mIntensity').textContent=avg('intensity')+'/5';
  document.getElementById('mClarity').textContent=avg('clarity_score')+'/10';
  document.getElementById('mStress').textContent=avg('stress_level')+'/5';
}


function renderDonut(records) {
  const counts={stable:0,monitor:0,escalate:0};
  records.forEach(r=>{const s=(r.signal||'').toLowerCase();if(s in counts)counts[s]++;});
  const total=records.length;
  document.getElementById('donutTotal').textContent=total;
  const colors={stable:'#16a34a',monitor:'#d97706',escalate:'#dc2626'};
  const labels={stable:'Stable',monitor:'Monitor',escalate:'Escalate'};
  document.getElementById('donutLegend').innerHTML=Object.keys(counts).map(k=>{
    const pct=total?((counts[k]/total)*100).toFixed(1):'0.0';
    return `<div class="legend-item"><div class="legend-left"><div class="legend-dot" style="background:${colors[k]}"></div><span class="legend-name">${labels[k]}</span></div><div><span class="legend-pct">${pct}%</span><span class="legend-count">(${counts[k]})</span></div></div>`;
  }).join('');
  if(chartDonut)chartDonut.destroy();
  chartDonut=new Chart(document.getElementById('chartDonut').getContext('2d'),{
    type:'doughnut',
    data:{labels:['Stable','Monitor','Escalate'],datasets:[{data:[counts.stable,counts.monitor,counts.escalate],backgroundColor:['#16a34a','#d97706','#dc2626'],borderColor:'#ffffff',borderWidth:3,hoverOffset:6}]},
    options:{cutout:'68%',responsive:true,maintainAspectRatio:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>{const pct=total?((ctx.parsed/total)*100).toFixed(1):'0.0';return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;}}}}
  }});
}


function renderLine(records) {
  const weekMap={};
  records.forEach(r=>{
    const d=new Date(r.checked_at),week=getISOWeekLabel(d);
    if(!weekMap[week])weekMap[week]={intensity:[],clarity:[],stress:[]};
    if(r.intensity!=null)weekMap[week].intensity.push(r.intensity);
    if(r.clarity_score!=null)weekMap[week].clarity.push(r.clarity_score);
    if(r.stress_level!=null)weekMap[week].stress.push(r.stress_level);
  });
  const weeks=Object.keys(weekMap).sort();
  const avg=arr=>arr.length?+(arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(2):null;
  if(chartLine)chartLine.destroy();
  const ctx=document.getElementById('chartLine').getContext('2d');
  const grad=ctx.createLinearGradient(0,0,0,240);
  grad.addColorStop(0,'rgba(26,122,122,.25)');grad.addColorStop(1,'rgba(26,122,122,.01)');
  chartLine=new Chart(ctx,{
    type:'line',
    data:{labels:weeks,datasets:[
      {label:'Intensity',data:weeks.map(w=>avg(weekMap[w].intensity)),borderColor:'#1a7a7a',backgroundColor:grad,borderWidth:2.5,tension:.4,fill:true,pointRadius:4,pointBackgroundColor:'#1a7a7a',pointBorderColor:'#fff',pointBorderWidth:2},
      {label:'Clarity',data:weeks.map(w=>avg(weekMap[w].clarity)),borderColor:'#6b2d99',backgroundColor:'transparent',borderWidth:2.5,tension:.4,fill:false,pointRadius:4,pointBackgroundColor:'#6b2d99',pointBorderColor:'#fff',pointBorderWidth:2},
      {label:'Stress',data:weeks.map(w=>avg(weekMap[w].stress)),borderColor:'#d97706',backgroundColor:'transparent',borderWidth:2.5,tension:.4,fill:false,pointRadius:4,pointBackgroundColor:'#d97706',pointBorderColor:'#fff',pointBorderWidth:2}
    ]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      scales:{x:{grid:{color:'rgba(0,0,0,.04)'},ticks:{font:{size:11},color:'#9090a8',maxRotation:45}},y:{min:0,max:10,grid:{color:'rgba(0,0,0,.05)'},ticks:{font:{size:11},color:'#9090a8',stepSize:2}}},
      plugins:{legend:{position:'top',align:'end',labels:{font:{size:11,weight:'600'},color:'#5a5a7a',boxWidth:12,boxHeight:12,padding:12,usePointStyle:true,pointStyle:'circle'}},
      tooltip:{backgroundColor:'rgba(255,255,255,.97)',titleColor:'#1a1a2e',bodyColor:'#5a5a7a',borderColor:'#e8e4f0',borderWidth:1,padding:10,cornerRadius:8}}}
  });
}


function renderBar(records) {
  const freq={};ALL_SYMPTOMS.forEach(s=>freq[s]=0);
  records.forEach(r=>{const syms=Array.isArray(r.symptoms)?r.symptoms:[];syms.forEach(s=>{const name=typeof s==='object'?s.name:s;if(name in freq)freq[name]++;});});
  const sorted=ALL_SYMPTOMS.map(s=>({name:s,count:freq[s],highRisk:HIGH_RISK.has(s)})).sort((a,b)=>b.count-a.count);
  document.getElementById('barWrap').style.height=(sorted.length*34+40)+'px';
  if(chartBar)chartBar.destroy();
  chartBar=new Chart(document.getElementById('chartBar').getContext('2d'),{
    type:'bar',
    data:{labels:sorted.map(s=>s.name),datasets:[{label:'Occurrences',data:sorted.map(s=>s.count),backgroundColor:sorted.map(s=>s.highRisk?'#dc2626':'#1a7a7a'),borderRadius:5,borderSkipped:false,barThickness:20}]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      scales:{x:{beginAtZero:true,grid:{color:'rgba(0,0,0,.05)'},ticks:{font:{size:11},color:'#9090a8',precision:0}},y:{grid:{display:false},ticks:{font:{size:12},color:'#5a5a7a'}}},
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>` ${ctx.parsed.x} occurrence${ctx.parsed.x!==1?'s':''}`,title:ctx=>{const item=sorted[ctx[0].dataIndex];return item.name+(item.highRisk?' ⚠ High Risk':'');}},backgroundColor:'rgba(255,255,255,.97)',titleColor:'#1a1a2e',bodyColor:'#5a5a7a',borderColor:'#e8e4f0',borderWidth:1,padding:10,cornerRadius:8}}}
  });
}


function renderHistory(records) {
  const last20=records.slice(-20),track=document.getElementById('historyTrack');
  track.innerHTML='';
  last20.forEach(r=>{
    const sig=(r.signal||'stable').toLowerCase(),d=new Date(r.checked_at);
    const lbl=d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    const item=document.createElement('div');item.className='history-item';
    item.title=`${lbl} · ${sig.charAt(0).toUpperCase()+sig.slice(1)}`;
    item.innerHTML=`<div class="history-dot ${sig}"></div><div class="history-date">${lbl}</div>`;
    track.appendChild(item);
  });
}


function avgField(records,key){const v=records.map(r=>r[key]).filter(v=>v!=null&&!isNaN(v));return v.length?+(v.reduce((a,b)=>a+b,0)/v.length).toFixed(1):0;}


function renderIntelligence(records) {
  const n=records.length;
  const uniqueUsers=new Set(records.map(r=>r.user_id).filter(Boolean)).size;
  const escalateCount=records.filter(r=>(r.signal||'').toLowerCase()==='escalate').length;
  const escalatePct=n?(escalateCount/n*100):0;
  const avgIntensity=avgField(records,'intensity');
  const avgClarity=avgField(records,'clarity_score');
  const avgStress=avgField(records,'stress_level');
  const dates=records.map(r=>new Date(r.checked_at)).filter(d=>!isNaN(d));
  const weekSpan=dates.length>=2?Math.round((Math.max(...dates)-Math.min(...dates))/(7*24*3600*1000)):0;
  const symSet=new Set();
  records.forEach(r=>{const syms=Array.isArray(r.symptoms)?r.symptoms:[];syms.forEach(s=>symSet.add(typeof s==='object'?s.name:s));});
  const symDiversity=symSet.size;


  // RWE Grade
  let rweScore=0;
  if(n>=500)rweScore+=4;else if(n>=100)rweScore+=3;else if(n>=50)rweScore+=2;else if(n>=10)rweScore+=1;
  if(uniqueUsers>=200)rweScore+=3;else if(uniqueUsers>=50)rweScore+=2;else if(uniqueUsers>=10)rweScore+=1;
  if(weekSpan>=52)rweScore+=3;else if(weekSpan>=12)rweScore+=2;else if(weekSpan>=4)rweScore+=1;
  if(symDiversity>=8)rweScore+=2;else if(symDiversity>=4)rweScore+=1;
  const rweGrade=rweScore>=10?'A':rweScore>=7?'B':rweScore>=4?'C':'D';
  const rweLabels={A:'RWE-Ready',B:'Near Threshold',C:'Building Evidence',D:'Early Stage'};
  document.getElementById('rweGrade').textContent=rweGrade;
  document.getElementById('rweGradeLabel').textContent=rweLabels[rweGrade];
  document.getElementById('rweRows').innerHTML=`
    <div class="intel-row"><span class="intel-row-icon">👥</span><span><strong>${uniqueUsers}</strong> unique patient IDs${uniqueUsers<50?' — target 50+ for initial pharma conversations':' — sufficient for partner engagement'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">📅</span><span><strong>${weekSpan} weeks</strong> longitudinal depth${weekSpan<12?' — target 12+ weeks for trend validity':' — statistically valid trend window'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">🧬</span><span><strong>${symDiversity} symptoms</strong> tracked — ${symDiversity>=8?'strong':'growing'} phenotypic diversity</span></div>
    <div class="intel-row"><span class="intel-row-icon">🚨</span><span><strong>${escalatePct.toFixed(1)}% escalate rate</strong> — ${escalatePct>20?'high clinical burden signal':'clinically meaningful signal'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">🔐</span><span>HIPAA Safe Harbor eligible · Supabase RLS compliant</span></div>`;
  document.getElementById('rweTags').innerHTML=['FDA RWE Framework','HIPAA De-ID','Symptom Phenotyping','Perimenopausal Cohort','PRO Data','Longitudinal Signal'].map(t=>`<span class="intel-tag">${t}</span>`).join('');


  // Benefits
  const workforceRisk=avgIntensity>3.5||avgStress>3.5||escalatePct>25?'HIGH':avgIntensity>2.5||avgStress>2.5||escalatePct>15?'MODERATE':'LOW';
  const presenteeismIndex=avgClarity?((10-avgClarity)/10*100).toFixed(0):'N/A';
  document.getElementById('benefitsGrade').textContent=workforceRisk;
  document.getElementById('benefitsGradeLabel').textContent='Workforce Risk Index';
  document.getElementById('benefitsRows').innerHTML=`
    <div class="intel-row"><span class="intel-row-icon">🧠</span><span><strong>Cognitive Presenteeism: ${presenteeismIndex}%</strong> — ${presenteeismIndex>40?'significant productivity drag':'within manageable range'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">📉</span><span><strong>Avg Clarity: ${avgClarity}/10</strong> — ${avgClarity<6?'below functional threshold':'within acceptable range'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">😰</span><span><strong>Avg Stress: ${avgStress}/5</strong> — ${avgStress>3?'elevated; absenteeism risk profile':'manageable stress burden'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">🏥</span><span><strong>${escalatePct.toFixed(1)}% escalate signals</strong> — ${escalatePct>15?'triggers EAP referral threshold':'below EAP escalation threshold'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">📋</span><span>Maps to SHRM Menopause Benefits Framework · EAP integration opportunity</span></div>`;
  document.getElementById('benefitsTags').innerHTML=['Menopause Benefits','EAP Integration','CFO Business Case','SHRM Framework','Presenteeism Analytics','Absenteeism Risk'].map(t=>`<span class="intel-tag">${t}</span>`).join('');


  // Data Asset
  let dataScore=0;
  if(n>=1000)dataScore+=4;else if(n>=200)dataScore+=3;else if(n>=50)dataScore+=2;else if(n>=10)dataScore+=1;
  if(uniqueUsers>=500)dataScore+=3;else if(uniqueUsers>=100)dataScore+=2;else if(uniqueUsers>=20)dataScore+=1;
  if(weekSpan>=104)dataScore+=3;else if(weekSpan>=52)dataScore+=2;else if(weekSpan>=12)dataScore+=1;
  const dataGrade=dataScore>=9?'A+':dataScore>=7?'A':dataScore>=5?'B':dataScore>=3?'C':'D';
  const dataLabels={'A+':'Premium Asset','A':'High Value','B':'Commercial Grade','C':'Pre-Commercial','D':'Seed Dataset'};
  const recordValue=dataScore>=9?'$250–500':dataScore>=7?'$100–250':dataScore>=5?'$50–100':'$10–50';
  document.getElementById('dataGrade').textContent=dataGrade;
  document.getElementById('dataGradeLabel').textContent=dataLabels[dataGrade];
  document.getElementById('dataRows').innerHTML=`
    <div class="intel-row"><span class="intel-row-icon">💰</span><span><strong>Est. value: ${recordValue}/record</strong> — pharma licensing benchmark for de-identified PRO datasets</span></div>
    <div class="intel-row"><span class="intel-row-icon">📊</span><span><strong>${n.toLocaleString()} records</strong> · <strong>${uniqueUsers} users</strong> · ${weekSpan} week span</span></div>
    <div class="intel-row"><span class="intel-row-icon">🔑</span><span><strong>Proprietary signal algorithm</strong> is defensible IP vs. raw symptom surveys</span></div>
    <div class="intel-row"><span class="intel-row-icon">🏗️</span><span>${n>=200?'OMOP CDM mapping feasible — opens CRO channels':'Scale to 200+ records before OMOP conversion'}</span></div>
    <div class="intel-row"><span class="intel-row-icon">🤝</span><span>${n>=100?'Ready for Astellas, Bayer, Organon conversations':'Build to 100 records for first pharma conversation'}</span></div>`;
