function showState(name) {
  ['Loading','Error','Empty'].forEach(s=>{ document.getElementById('state'+s).style.display=(s===name)?'flex':'none'; });
  document.getElementById('dashboard').classList.toggle('visible',name==='Dashboard');
  document.getElementById('totalBadge').style.display=(name==='Dashboard')?'flex':'none';
