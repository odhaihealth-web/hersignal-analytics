function populateUserFilter(records) {
  const users=[...new Set(records.map(r=>r.user_id).filter(Boolean))];
  const sel=document.getElementById('userFilter');
  sel.innerHTML='<option value="all">All Users ('+records.length+' check-ins)</option>';
  users.forEach((uid,i)=>{
    const count=records.filter(r=>r.user_id===uid).length;
    const opt=document.createElement('option');
    opt.value=uid; opt.textContent='User '+(i+1)+' · '+count+' check-in'+(count!==1?'s':''); opt.title=uid;
    sel.appendChild(opt);
  });
  document.getElementById('filterBar').style.display=users.length>=2?'flex':'none';
}


function applyFilter() {
  const val=document.getElementById('userFilter').value;
  const filtered=val==='all'?ALL_RECORDS:ALL_RECORDS.filter(r=>r.user_id===val);
  document.getElementById('filterCount').textContent=val==='all'?'':filtered.length+' check-in'+(filtered.length!==1?'s':'')+' for this user';
  renderDashboard(filtered);
}


