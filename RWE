function setMilestone(id, status, metricId, metricText, metricMet) {
  const el=document.getElementById(id);
  if(!el)return;
  if(status==='done'){el.className='milestone-status done';el.textContent='✓';}
  else if(status==='active'){el.className='milestone-status active';el.textContent='→';}
  else{el.className='milestone-status locked';el.textContent='🔒';}
  if(metricId){
    const m=document.getElementById(metricId);
    if(m){m.textContent=metricText;m.className='milestone-metric '+(metricMet?'met':'unmet');}
  }
}


function setProgress(fillId, pctId, pct) {
  const fill=document.getElementById(fillId),label=document.getElementById(pctId);
  if(fill)fill.style.width=pct+'%';
  if(label)label.textContent=Math.round(pct)+'%';
}


function renderChecklist(records) {
  const n=records.length;
  const uniqueUsers=new Set(records.map(r=>r.user_id).filter(Boolean)).size;
  const escalateCount=records.filter(r=>(r.signal||'').toLowerCase()==='escalate').length;
  const dates=records.map(r=>new Date(r.checked_at)).filter(d=>!isNaN(d));
  const weekSpan=dates.length>=2?Math.round((Math.max(...dates)-Math.min(...dates))/(7*24*3600*1000)):0;
  const symSet=new Set();
  records.forEach(r=>{const syms=Array.isArray(r.symptoms)?r.symptoms:[];syms.forEach(s=>symSet.add(typeof s==='object'?s.name:s));});


  // Pharma checklist
  const p1=uniqueUsers>=10,p2=weekSpan>=4,p3=symSet.size>=6;
  setMilestone('ps1',p1?'done':'active','ps1m',p1?`✓ ${uniqueUsers} users`:`${uniqueUsers}/10 users`,p1);
  setMilestone('ps2',p2?'done':'active','ps2m',p2?`✓ ${weekSpan} weeks`:`${weekSpan}/4 weeks`,p2);
  setMilestone('ps3',p3?'done':'active','ps3m',p3?`✓ ${symSet.size} symptoms`:`${symSet.size}/6 symptoms`,p3);
  setMilestone('ps4',uniqueUsers>=50?'done':'locked','ps4m',`${uniqueUsers}/50 users`,uniqueUsers>=50);
  const pharmaDone=[p1,p2,p3,uniqueUsers>=50,weekSpan>=12,false,false,false,false].filter(Boolean).length;
  setProgress('pharmaProgressFill','pharmaProgressPct',Math.round(pharmaDone/9*100));
  const pharmaBanner=document.getElementById('pharmaBanner');
  if(pharmaBanner){
    const next=!p1?`Recruit ${10-uniqueUsers} more users to unlock Phase 1`:!p2?`${4-weekSpan} more weeks of data needed`:!p3?`Track ${6-symSet.size} more symptom types`:uniqueUsers<50?`Recruit ${50-uniqueUsers} more users to unlock pharma conversations`:'Phase 1 complete — begin HIPAA de-identification';
    pharmaBanner.innerHTML=`<div class="unlock-banner">⚡ Next milestone: ${next}</div>`;
  }


  // Benefits checklist
  const b1=n>=20,b2=escalateCount>0;
  setMilestone('bs1',b1?'done':'active','bs1m',b1?`✓ ${n} check-ins`:`${n}/20 check-ins`,b1);
  setMilestone('bs2',b2?'done':'active','bs2m',b2?`✓ ${escalateCount} escalate signal${escalateCount!==1?'s':''}`:'No escalate signals yet',b2);
  const benefitsDone=[b1,b2,false,false,false,false,false].filter(Boolean).length;
  setProgress('benefitsProgressFill','benefitsProgressPct',Math.round(benefitsDone/7*100));


  // Data licensing checklist
  const d3=n>=50;
  setMilestone('ds3',d3?'done':'active','ds3m',d3?`✓ ${n} records`:`${n}/50 records`,d3);
  const dataDone=[true,true,d3,false,false,false,false].filter(Boolean).length;
  setProgress('dataProgressFill','dataProgressPct',Math.round(dataDone/7*100));


  // Clinical checklist
  const c3=uniqueUsers>=5;
  setMilestone('cs3',c3?'done':'active','cs3m',c3?`✓ ${uniqueUsers} users active`:`${uniqueUsers}/5 users needed`,c3);
  const clinicalDone=[true,true,c3,false,false,false,false,false].filter(Boolean).length;
  setProgress('clinicalProgressFill','clinicalProgressPct',Math.round(clinicalDone/8*100));
}


function renderNotes(records) {
  const withNotes=records.filter(r=>r.notes&&r.notes.trim()).slice().reverse();
  const wrap=document.getElementById('notesWrap');
  if(!withNotes.length){wrap.innerHTML='<div class="no-notes">No notes recorded yet.</div>';return;}
  const rows=withNotes.map(r=>{
    const sig=(r.signal||'stable').toLowerCase(),d=new Date(r.checked_at);
    const dateStr=d.toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'});
    const timeStr=d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
    return `<tr><td class="td-date">${dateStr}<br><span style="color:var(--text-muted);font-size:.72rem;">${timeStr}</span></td><td><span class="signal-badge ${sig}">${sig}</span></td><td class="td-notes">${escapeHtml(r.notes.trim())}</td></tr>`;
  }).join('');
  wrap.innerHTML=`<table><thead><tr><th>Date</th><th>Signal</th><th>Notes</th></tr></thead><tbody>${rows}</tbody></table>`;
}


function getISOWeekLabel(date){const d=new Date(Date.UTC(date.getFullYear(),date.getMonth(),date.getDate()));const day=d.getUTCDay()||7;d.setUTCDate(d.getUTCDate()+4-day);const ys=new Date(Date.UTC(d.getUTCFullYear(),0,1));const week=Math.ceil((((d-ys)/86400000)+1)/7);return `W${String(week).padStart(2,'0')} '${String(d.getUTCFullYear()).slice(2)}`;}
function escapeHtml(str){return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');}


