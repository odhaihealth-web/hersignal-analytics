<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HerSignal Analytics Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal: #0d4a4a; --teal-mid: #0f5c5c; --teal-light: #1a7a7a;
      --plum: #4a1a6b; --plum-light: #6b2d99;
      --gradient: linear-gradient(135deg, #0d4a4a 0%, #2d1a5c 50%, #4a1a6b 100%);
      --warm-white: #faf9f7; --stable: #16a34a; --monitor: #d97706; --escalate: #dc2626;
      --card-bg: #ffffff; --border: #e8e4f0; --text-primary: #1a1a2e;
      --text-secondary: #5a5a7a; --text-muted: #9090a8;
      --shadow-sm: 0 1px 3px rgba(13,74,74,.07), 0 1px 2px rgba(74,26,107,.05);
      --radius: 14px; --radius-sm: 8px;
    }
    body { font-family: 'Inter', sans-serif; background: var(--warm-white); color: var(--text-primary); min-height: 100vh; line-height: 1.5; }
    .header { background: var(--gradient); color: #fff; padding: 2rem 1.5rem 2.5rem; position: relative; overflow: hidden; }
    .header::before { content: ''; position: absolute; top: -60px; right: -60px; width: 220px; height: 220px; border-radius: 50%; background: rgba(255,255,255,.05); pointer-events: none; }
    .header::after { content: ''; position: absolute; bottom: -80px; left: 30%; width: 300px; height: 300px; border-radius: 50%; background: rgba(255,255,255,.04); pointer-events: none; }
    .header-inner { max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 1rem; position: relative; z-index: 1; }
    .header-brand { display: flex; align-items: center; gap: .75rem; margin-bottom: .5rem; }
    .header-logo { width: 42px; height: 42px; background: rgba(255,255,255,.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,.2); }
    .header-wordmark { font-size: 1.1rem; font-weight: 700; letter-spacing: .02em; opacity: .95; }
    .header-title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 800; letter-spacing: -.02em; line-height: 1.2; }
    .header-subtitle { font-size: .875rem; opacity: .75; margin-top: .3rem; }
    .header-actions { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }
    .badge-total { background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25); border-radius: 999px; padding: .35rem .9rem; font-size: .85rem; font-weight: 600; backdrop-filter: blur(4px); display: flex; align-items: center; gap: .4rem; }
    .badge-total .dot { width: 7px; height: 7px; border-radius: 50%; background: #4ade80; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }
    .btn-refresh { background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.3); color: #fff; border-radius: var(--radius-sm); padding: .5rem 1.1rem; font-family: inherit; font-size: .875rem; font-weight: 600; cursor: pointer; transition: background .2s, transform .15s; display: flex; align-items: center; gap: .4rem; backdrop-filter: blur(4px); }
    .btn-refresh:hover { background: rgba(255,255,255,.25); transform: translateY(-1px); }
    .btn-refresh.spinning svg { animation: spin .7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .main { max-width: 1200px; margin: 0 auto; padding: 2rem 1.25rem 3rem; }
    .state-screen { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 340px; gap: 1rem; text-align: center; }
    .state-icon { font-size: 3rem; }
    .state-title { font-size: 1.25rem; font-weight: 700; }
    .state-msg { font-size: .9rem; color: var(--text-secondary); max-width: 380px; }
    .btn-retry { background: var(--gradient); color: #fff; border: none; border-radius: var(--radius-sm); padding: .6rem 1.4rem; font-family: inherit; font-size: .875rem; font-weight: 600; cursor: pointer; margin-top: .5rem; }
    .spinner { width: 44px; height: 44px; border: 3px solid var(--border); border-top-color: var(--teal-light); border-radius: 50%; animation: spin .8s linear infinite; }
    #dashboard { display: none; }
    #dashboard.visible { display: block; }
    .section-label { font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: .75rem; }
    .filter-bar { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: .9rem 1.25rem; margin-bottom: 1.5rem; box-shadow: var(--shadow-sm); }
    .filter-label { font-size: .78rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; white-space: nowrap; }
    .filter-select { font-family: inherit; font-size: .875rem; font-weight: 500; color: var(--text-primary); background: var(--warm-white); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: .4rem .9rem; cursor: pointer; outline: none; min-width: 200px; }
    .filter-select:focus { border-color: var(--teal-light); }
    .filter-count { font-size: .8rem; color: var(--text-muted); margin-left: auto; }
    .metrics-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
    @media (max-width: 800px) { .metrics-row { grid-template-columns: repeat(2, 1fr); } }
    .stat-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.25rem 1rem; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gradient); border-radius: var(--radius) var(--radius) 0 0; }
    .stat-card .stat-icon { font-size: 1.4rem; margin-bottom: .5rem; }
    .stat-card .stat-value { font-size: 2rem; font-weight: 800; letter-spacing: -.03em; color: var(--teal); line-height: 1; }
    .stat-card .stat-label { font-size: .78rem; font-weight: 600; color: var(--text-secondary); margin-top: .35rem; text-transform: uppercase; letter-spacing: .05em; }
    .stat-card .stat-sub { font-size: .75rem; color: var(--text-muted); margin-top: .2rem; }
    .charts-row { display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; margin-bottom: 1.5rem; }
    @media (max-width: 760px) { .charts-row { grid-template-columns: 1fr; } }
    .panel { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem 1.4rem 1.2rem; box-shadow: var(--shadow-sm); }
    .panel-full { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem 1.4rem 1.2rem; box-shadow: var(--shadow-sm); margin-bottom: 1.5rem; }
    .panel-title { font-size: .95rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }
    .donut-wrap { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
    .donut-canvas-wrap { position: relative; width: 180px; height: 180px; }
    .donut-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none; }
    .donut-center-val { font-size: 1.6rem; font-weight: 800; color: var(--teal); line-height: 1; }
    .donut-center-lbl { font-size: .65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-top: .15rem; }
    .donut-legend { width: 100%; display: flex; flex-direction: column; gap: .5rem; }
    .legend-item { display: flex; align-items: center; justify-content: space-between; font-size: .82rem; }
    .legend-left { display: flex; align-items: center; gap: .5rem; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .legend-name { color: var(--text-secondary); font-weight: 500; }
    .legend-pct { font-weight: 700; color: var(--text-primary); }
    .legend-count { font-size: .75rem; color: var(--text-muted); margin-left: .25rem; }
    .chart-canvas-wrap { position: relative; width: 100%; }
    .chart-canvas-wrap canvas { width: 100% !important; }
    .history-scroll { overflow-x: auto; padding-bottom: .5rem; }
    .history-track { display: flex; align-items: flex-end; gap: .6rem; min-width: max-content; padding: .5rem .25rem 0; }
    .history-item { display: flex; flex-direction: column; align-items: center; gap: .4rem; }
    .history-dot { width: 18px; height: 18px; border-radius: 50%; border: 2px solid rgba(0,0,0,.08); flex-shrink: 0; transition: transform .15s; cursor: default; }
    .history-dot:hover { transform: scale(1.3); }
    .history-dot.stable { background: var(--stable); }
    .history-dot.monitor { background: var(--monitor); }
    .history-dot.escalate { background: var(--escalate); }
    .history-date { font-size: .62rem; color: var(--text-muted); writing-mode: vertical-rl; transform: rotate(180deg); white-space: nowrap; max-height: 52px; }
    .history-legend { display: flex; gap: 1.2rem; margin-top: 1rem; flex-wrap: wrap; }
    .hl-item { display: flex; align-items: center; gap: .4rem; font-size: .78rem; color: var(--text-secondary); }
    .hl-dot { width: 10px; height: 10px; border-radius: 50%; }
    .notes-table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    thead th { text-align: left; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); padding: .5rem .75rem .75rem; border-bottom: 1px solid var(--border); }
    tbody tr { border-bottom: 1px solid #f0edf8; transition: background .15s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #faf8ff; }
    tbody td { padding: .75rem; vertical-align: top; }
    .td-date { white-space: nowrap; color: var(--text-secondary); font-size: .8rem; font-weight: 500; }
    .signal-badge { display: inline-flex; align-items: center; gap: .3rem; border-radius: 999px; padding: .2rem .65rem; font-size: .72rem; font-weight: 700; text-transform: capitalize; white-space: nowrap; }
    .signal-badge.stable { background: #dcfce7; color: #15803d; }
    .signal-badge.monitor { background: #fef3c7; color: #b45309; }
    .signal-badge.escalate { background: #fee2e2; color: #b91c1c; }
    .signal-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; }
    .signal-badge.stable::before { background: var(--stable); }
    .signal-badge.monitor::before { background: var(--monitor); }
    .signal-badge.escalate::before { background: var(--escalate); }
    .td-notes { color: var(--text-secondary); font-size: .83rem; line-height: 1.5; max-width: 480px; }
    .no-notes { text-align: center; padding: 2.5rem 1rem; color: var(--text-muted); font-size: .875rem; }
    /* ── Strategic Intelligence ── */
    .exec-summary { background: var(--gradient); color: #fff; border-radius: var(--radius); padding: 1.5rem 1.75rem; margin-bottom: 1.5rem; position: relative; overflow: hidden; }
    .exec-summary::after { content: ''; position: absolute; right: -40px; top: -40px; width: 180px; height: 180px; border-radius: 50%; background: rgba(255,255,255,.04); pointer-events: none; }
    .exec-summary-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; opacity: .6; margin-bottom: .4rem; }
    .exec-summary-text { font-size: .95rem; line-height: 1.65; opacity: .92; position: relative; z-index: 1; }
    .exec-badges { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .9rem; }
    .exec-badge { background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22); border-radius: 999px; padding: .25rem .75rem; font-size: .72rem; font-weight: 600; }
    .intel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
    @media (max-width: 900px) { .intel-grid { grid-template-columns: 1fr; } }
    .intel-card { border-radius: var(--radius); padding: 1.4rem; border: 1px solid transparent; color: #fff; }
    .intel-card.pharma { background: linear-gradient(135deg, #0d1f4a 0%, #1a2d6b 100%); border-color: #2d3f8a; }
    .intel-card.benefits { background: linear-gradient(135deg, #1a3a1a 0%, #2d5c2d 100%); border-color: #3a7a3a; }
    .intel-card.data-asset { background: linear-gradient(135deg, #3a1a4a 0%, #5c2d6b 100%); border-color: #7a3a9a; }
    .intel-card-icon { font-size: 1.8rem; margin-bottom: .75rem; }
    .intel-card-title { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; opacity: .65; margin-bottom: .2rem; }
    .intel-card-heading { font-size: 1rem; font-weight: 800; margin-bottom: .9rem; line-height: 1.3; }
    .intel-grade { display: inline-flex; align-items: center; gap: .5rem; background: rgba(255,255,255,.15); border-radius: 999px; padding: .3rem .9rem; font-size: .8rem; font-weight: 700; margin-bottom: 1rem; border: 1px solid rgba(255,255,255,.2); }
    .grade-val { font-size: 1.1rem; font-weight: 800; }
    .intel-rows { display: flex; flex-direction: column; gap: .55rem; }
    .intel-row { display: flex; align-items: flex-start; gap: .6rem; font-size: .79rem; opacity: .9; line-height: 1.4; }
    .intel-row-icon { flex-shrink: 0; font-size: .85rem; margin-top: .05rem; }
    .intel-row strong { font-weight: 700; opacity: 1; }
    .intel-divider { height: 1px; background: rgba(255,255,255,.12); margin: .9rem 0; }
    .intel-tag { display: inline-block; background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.18); border-radius: 4px; padding: .15rem .5rem; font-size: .67rem; font-weight: 600; margin: .15rem .15rem 0 0; letter-spacing: .03em; }
    /* ── Partnership Readiness Checklist ── */
    .checklist-section { margin-bottom: 1.5rem; }
    .checklist-tabs { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .ctab { background: var(--card-bg); border: 1px solid var(--border); border-radius: 999px; padding: .4rem 1rem; font-family: inherit; font-size: .8rem; font-weight: 600; color: var(--text-secondary); cursor: pointer; transition: all .2s; }
    .ctab:hover { border-color: var(--teal-light); color: var(--teal); }
    .ctab.active { background: var(--gradient); color: #fff; border-color: transparent; }
    .checklist-panel { display: none; }
    .checklist-panel.active { display: block; }
    .checklist-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); }
    .checklist-intro { font-size: .875rem; color: var(--text-secondary); margin-bottom: 1.25rem; line-height: 1.6; }
    .checklist-intro strong { color: var(--text-primary); }
    .milestone-group { margin-bottom: 1.5rem; }
    .milestone-group:last-child { margin-bottom: 0; }
    .milestone-group-title { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--text-muted); margin-bottom: .75rem; padding-bottom: .5rem; border-bottom: 1px solid var(--border); }
    .milestone-item { display: flex; align-items: flex-start; gap: .9rem; padding: .7rem 0; border-bottom: 1px solid #f5f3fb; }
    .milestone-item:last-child { border-bottom: none; }
    .milestone-status { flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .75rem; font-weight: 700; margin-top: .1rem; }
    .milestone-status.done { background: #dcfce7; color: #15803d; }
    .milestone-status.active { background: #fef3c7; color: #b45309; }
    .milestone-status.locked { background: #f1f0f8; color: var(--text-muted); }
    .milestone-body { flex: 1; }
    .milestone-title { font-size: .875rem; font-weight: 700; color: var(--text-primary); margin-bottom: .2rem; }
    .milestone-title.locked { color: var(--text-muted); }
    .milestone-desc { font-size: .8rem; color: var(--text-secondary); line-height: 1.5; }
    .milestone-metric { display: inline-block; background: #f0edf8; color: var(--plum); border-radius: 4px; padding: .1rem .45rem; font-size: .7rem; font-weight: 700; margin-top: .3rem; }
    .milestone-metric.met { background: #dcfce7; color: #15803d; }
    .milestone-metric.unmet { background: #fee2e2; color: #b91c1c; }
    .progress-bar-wrap { margin-bottom: 1.25rem; }
    .progress-bar-label { display: flex; justify-content: space-between; font-size: .78rem; font-weight: 600; color: var(--text-secondary); margin-bottom: .4rem; }
    .progress-bar-track { height: 8px; background: #f0edf8; border-radius: 999px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: var(--gradient); border-radius: 999px; transition: width .6s ease; }
    .unlock-banner { background: linear-gradient(135deg, #fef3c7, #fde68a); border: 1px solid #f59e0b; border-radius: var(--radius-sm); padding: .75rem 1rem; font-size: .82rem; color: #92400e; font-weight: 600; margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }
    /* Footer */
    .footer { background: var(--teal); color: rgba(255,255,255,.65); text-align: center; padding: 1.25rem 1rem; font-size: .8rem; }
    .footer a { color: rgba(255,255,255,.85); text-decoration: none; font-weight: 600; margin-right: 1.5rem; }
    .footer-row { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .5rem 1.5rem; }
  </style>
</head>
<body>


<header class="header">
  <div class="header-inner">
    <div>
      <div class="header-brand">
        <div class="header-logo">🌿</div>
        <span class="header-wordmark">HerSignal</span>
      </div>
      <h1 class="header-title">Analytics Dashboard</h1>
      <p class="header-subtitle">Live data · RWE Intelligence · Partnership Readiness</p>
    </div>
    <div class="header-actions">
      <div class="badge-total" id="totalBadge" style="display:none;">
        <span class="dot"></span>
        <span id="totalBadgeCount">0</span> check-ins
      </div>
      <button class="btn-refresh" id="btnRefresh" onclick="loadData()">
        <svg id="refreshIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M23 4v6h-6"/><path d="M1 20v-6h6"/>
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
        </svg>
        Refresh
      </button>
    </div>
  </div>
</header>


<main class="main">
  <div id="stateLoading" class="state-screen">
    <div class="spinner"></div>
    <p class="state-title">Loading analytics…</p>
    <p class="state-msg">Fetching live data from Supabase</p>
  </div>
  <div id="stateError" class="state-screen" style="display:none;">
    <div class="state-icon">⚠️</div>
    <p class="state-title">Unable to load data</p>
    <p class="state-msg" id="errorMsg">Could not connect to Supabase.</p>
    <button class="btn-retry" onclick="loadData()">Try Again</button>
  </div>
  <div id="stateEmpty" class="state-screen" style="display:none;">
    <div class="state-icon">📋</div>
    <p class="state-title">No check-ins yet</p>
    <p class="state-msg">Once users complete check-ins, data will appear here.</p>
  </div>


  <div id="dashboard">


    <!-- User Filter -->
    <div class="filter-bar" id="filterBar" style="display:none;">
      <span class="filter-label">👤 Filter by User</span>
      <select class="filter-select" id="userFilter" onchange="applyFilter()">
        <option value="all">All Users</option>
      </select>
      <span class="filter-count" id="filterCount"></span>
    </div>


    <!-- Key Metrics -->
    <p class="section-label">Key Metrics</p>
    <div class="metrics-row">
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-value" id="mTotal">—</div>
        <div class="stat-label">Total Check-Ins</div>
        <div class="stat-sub">All time</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🌡️</div>
        <div class="stat-value" id="mIntensity">—</div>
        <div class="stat-label">Avg Intensity</div>
        <div class="stat-sub">Scale 1–5</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🔮</div>
        <div class="stat-value" id="mClarity">—</div>
        <div class="stat-label">Avg Clarity</div>
        <div class="stat-sub">Scale 1–10</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">💫</div>
        <div class="stat-value" id="mStress">—</div>
        <div class="stat-label">Avg Stress</div>
        <div class="stat-sub">Scale 1–5</div>
      </div>
    </div>


    <!-- Charts -->
    <div class="charts-row">
      <div class="panel">
        <div class="panel-title">🎯 Signal Distribution</div>
        <div class="donut-wrap">
          <div class="donut-canvas-wrap">
            <canvas id="chartDonut" width="180" height="180"></canvas>
            <div class="donut-center">
              <span class="donut-center-val" id="donutTotal">0</span>
              <span class="donut-center-lbl">total</span>
            </div>
          </div>
          <div class="donut-legend" id="donutLegend"></div>
        </div>
      </div>
      <div class="panel">
        <div class="panel-title">📈 Weekly Trend</div>
        <div class="chart-canvas-wrap" style="height:240px;">
          <canvas id="chartLine"></canvas>
        </div>
      </div>
    </div>


    <div class="panel-full">
      <div class="panel-title">🩺 Symptom Frequency <span style="font-size:.72rem;font-weight:400;color:var(--escalate);margin-left:.5rem;">■ High Risk</span><span style="font-size:.72rem;font-weight:400;color:var(--teal-light);margin-left:.75rem;">■ Standard</span></div>
      <div class="chart-canvas-wrap" id="barWrap"><canvas id="chartBar"></canvas></div>
