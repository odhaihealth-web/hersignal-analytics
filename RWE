  // Executive Summary
  const readiness=rweGrade==='A'?'RWE-ready and commercially mature':rweGrade==='B'?'approaching commercial-grade RWE thresholds':'in active development toward RWE thresholds';
  document.getElementById('execText').innerHTML=`HerSignal has <strong>${n.toLocaleString()}</strong> longitudinal check-ins across <strong>${uniqueUsers}</strong> unique users, spanning <strong>${weekSpan} weeks</strong>. The dataset is ${readiness}. Workforce health signal indicates <strong>${workforceRisk.toLowerCase()} risk</strong> with a ${presenteeismIndex}% cognitive presenteeism index and ${escalatePct.toFixed(1)}% escalation rate — directly relevant to employer benefit plan design. The proprietary signal algorithm constitutes defensible IP with an estimated licensing value of <strong>${recordValue}/record</strong>. ${n>=100?'Cohort is sufficient to initiate pharma partnership conversations.':'Scaling to 100+ users activates the full commercial opportunity.'}`;
  document.getElementById('execBadges').innerHTML=[rweGrade==='A'?'✅ RWE-Ready':'📈 RWE: '+rweGrade+' Grade','Workforce: '+workforceRisk+' Risk','Data: '+recordValue+'/record',uniqueUsers+' Unique Users',weekSpan+'wk Dataset','Signal IP: Proprietary'].map(b=>`<span class="exec-badge">${b}</span>`).join('');
